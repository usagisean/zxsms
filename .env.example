APP_NAME="ZXAIHUB SMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Docker 部署端口：默认只绑定本机 18081，适合前面再接 Nginx/Caddy/NPM 反代
COMPOSE_PROJECT_NAME=zxsms
SMS_DOCKER_HTTP_BIND=127.0.0.1
SMS_DOCKER_HTTP_PORT=18081


LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=zxaihub_sms
DB_USERNAME=zxsms
DB_PASSWORD=change_this_db_password
DB_ROOT_PASSWORD=change_this_root_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# 接码上游模式：inventory 表示后台导入号码库存后站内售卖；herosms 表示旧 HeroSMS 自动上游
SMS_PROVIDER=inventory

# HeroSMS 接码站配置
HEROSMS_API_KEY=
HEROSMS_BASE_URL=https://hero-sms.com/stubs/handler_api.php
HEROSMS_TIMEOUT=15
HEROSMS_SERVICE_LANG=cn

SMS_USD_CNY_RATE=7.3
SMS_DEFAULT_MARKUP_MULTIPLIER=1.35
SMS_DEFAULT_FIXED_FEE=0
SMS_DEFAULT_MIN_PROFIT=0.5
SMS_DEFAULT_MIN_PRICE=3
SMS_REPRICE_TOLERANCE=0
SMS_PROVIDER_COST_TOLERANCE_USD=0
SMS_ORDER_EXPIRE_MINUTES=15
SMS_RECHARGE_EXPIRE_MINUTES=15
SMS_POLL_INTERVAL_SECONDS=8
SMS_POLL_TIMEOUT_MINUTES=20

SMS_ADMIN_USER=admin
SMS_ADMIN_PASSWORD=

# 易支付：截图里的支付宝/微信共用 pid、网关地址、密钥
SMS_YIPAY_PID=
SMS_YIPAY_GATEWAY=
SMS_YIPAY_KEY=
SMS_YIPAY_ALIPAY_ENABLED=true
SMS_YIPAY_ALIPAY_PAY_CHECK=alipay
SMS_YIPAY_WXPAY_ENABLED=true
SMS_YIPAY_WXPAY_PAY_CHECK=wxpay

# Epusdt：截图里的 USDT(BEP-20) / USDT(TRC-20)
SMS_EPUSDT_API_KEY=
SMS_EPUSDT_BASE_URL=
SMS_EPUSDT_BEP20_ENABLED=true
SMS_EPUSDT_BEP20_PAY_CHECK=usdt.bep20
SMS_EPUSDT_TRC20_ENABLED=true
SMS_EPUSDT_TRC20_PAY_CHECK=usdt.trc20

# 自定义后台地址
ADMIN_PATH=sms-admin
